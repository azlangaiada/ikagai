# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/your_db

# Payload secret — generate with: openssl rand -hex 32
PAYLOAD_SECRET=CHANGE_ME

# Public URL of this CMS (used by SEO plugin + live preview)
PAYLOAD_URL=http://localhost:4004

# Public URL of the frontend (used for revalidation callbacks)
FRONTEND_URL=http://localhost:3004

# Shared with packages/web — guards /api/revalidate
REVALIDATION_SECRET=CHANGE_ME

# Guards Payload jobs endpoint
CRON_SECRET=CHANGE_ME

# Guards /api/web-manager/* — generate with: openssl rand -hex 32
WEB_MANAGER_API_SECRET=CHANGE_ME

# Comma-separated IP allowlist for web-manager (evaluated after the reverse proxy)
WEB_MANAGER_ALLOWED_IPS=127.0.0.1

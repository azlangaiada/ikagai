# Frontend port
PORT=3004

# Internal URL to reach the CMS (server-side fetch)
PAYLOAD_URL=http://localhost:4004

# Public URL the browser uses for Payload media/assets
VITE_PAYLOAD_URL=http://localhost:4004

# Public frontend URL
SITE_URL=http://localhost:3004
VITE_SITE_URL=http://localhost:3004

# Shared with packages/cms — received on /api/revalidate
REVALIDATION_SECRET=CHANGE_ME

# Guards /api/preview
PREVIEW_SECRET=CHANGE_ME
